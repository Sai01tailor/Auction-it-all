<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Invoice - BidKar</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        
        body { 
            font-family: 'Inter', sans-serif; 
            padding: 40px; 
            color: #333;
            background-color: #fff;
            line-height: 1.6;
        }
        
        .watermark { 
            position: fixed; 
            top: 40%;
            left: 15%;
            opacity: 0.05; 
            font-size: 80px; 
            font-weight: 800;
            transform: rotate(-35deg); 
            z-index: -1; 
            pointer-events: none;
            color: #000;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .brand-name {
            font-size: 32px;
            font-weight: 700;
            color: #1a1a1a;
            margin: 0;
            letter-spacing: -1px;
        }

        .invoice-title {
            text-align: right;
        }

        .invoice-title h2 {
            margin: 0;
            font-size: 28px;
            color: #002366; /* Deep Royal Navy */
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .invoice-title p {
            margin: 5px 0 0 0;
            font-size: 14px;
            color: #666;
        }

        .details-grid {
            display: flex;
            justify-content: space-between;
            margin-bottom: 40px;
        }

        .details-section {
            width: 48%;
            background-color: #f8fafc;
            padding: 20px;
            border-radius: 8px;
            box-sizing: border-box;
        }

        .details-section h4 {
            margin-top: 0;
            margin-bottom: 10px;
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .details-section p {
            margin: 4px 0;
            font-size: 14px;
        }

        .table-container {
            margin-bottom: 40px;
        }

        .table { 
            width: 100%; 
            border-collapse: collapse; 
        }

        .table th { 
            background-color: #f1f5f9; 
            color: #334155;
            text-align: left;
            padding: 12px 15px;
            font-weight: 600;
            font-size: 14px;
            border-bottom: 2px solid #cbd5e1;
        }

        .table td { 
            padding: 15px; 
            border-bottom: 1px solid #e2e8f0; 
            font-size: 15px;
        }

        .amount-col {
            text-align: right !important;
        }

        .highlight-row td {
            background-color: #fff8e1;
            color: #002366;
            font-weight: 700;
            border-bottom: 2px solid #fece44;
        }

        .footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
            font-size: 12px;
            color: #64748b;
            text-align: center;
        }

        .footer p {
            margin: 4px 0;
        }
    </style>
</head>
<body>
    <div class="watermark">VERIFIED BY BIDKAR</div>
    
    <div class="header">
        <div>
            <h1 class="brand-name">BidKar</h1>
            <p style="margin: 5px 0; color: #666; font-size: 14px;">The Premier Auction Platform</p>
        </div>
        <div class="invoice-title">
            <h2>INVOICE</h2>
            <p><strong>Date:</strong> <%= date %></p>
            <p><strong>Transaction ID:</strong> <%= transactionId %></p>
        </div>
    </div>

    <div class="details-grid">
        <div class="details-section">
            <h4>Billed To (Winner)</h4>
            <p><strong>Name:</strong> <%= buyerName %></p>
            <p><strong>User ID:</strong> <%= buyerId %></p>
        </div>
        <div class="details-section">
            <h4>Sold By (Seller)</h4>
            <p><strong>Name:</strong> <%= sellerName %></p>
            <p><strong>Seller ID:</strong> <%= sellerId %></p>
        </div>
    </div>

    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Item Description</th>
                    <th class="amount-col">Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <strong><%= itemName %></strong><br>
                        <span style="font-size: 12px; color: #64748b;">Final Winning Bid (Hammer Price)</span>
                    </td>
                    <td class="amount-col">₹<%= hammerPrice %></td>
                </tr>
                <tr>
                    <td>
                        Security Deposit (10%)<br>
                        <span style="font-size: 12px; color: #64748b;">Paid online via BidKar Wallet</span>
                    </td>
                    <td class="amount-col">₹<%= securityDeposit %></td>
                </tr>
                <tr class="highlight-row">
                    <td>
                        Balance Due Offline (90%)<br>
                        <span style="font-size: 12px; color: #002366;">To be paid directly to seller at handoff</span>
                    </td>
                    <td class="amount-col">₹<%= offlineBalance %></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="footer">
        <p>This is a system-generated document and serves as proof of the auction result.</p>
        <p>For support, please visit <strong>www.bidkar.com/support</strong> or contact <strong>support@bidkar.com</strong></p>
        <p>Note: Applicable TDS/GST liabilities must be settled directly between buyer and seller as per Indian E-commerce guidelines.</p>
    </div>
</body>
</html>