{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Accept-Encoding",
          "value": "gzip, deflate, br"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://auction-it-all.onrender.com/sitemap.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "https://auction-it-all.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://auction-it-all.onrender.com/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
